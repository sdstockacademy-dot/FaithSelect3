<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for Firebase and streaming -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Check network state before fetching -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Foreground service for background audio playback -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Wake lock to keep CPU on during playback -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".FaithSelectApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_splash_om"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_splash_om"
        android:supportsRtl="true"
        android:theme="@style/Theme.FaithSelect"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <!-- Main launcher activity -->
        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FaithSelect.Splash"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Background Audio Playback Service -->
        <service
            android:name=".presentation.audio.AudioPlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!-- Firebase Cloud Messaging Service -->
        <service
            android:name=".utils.FaithFCMService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Firebase default notification channel -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="faith_select_daily" />

        <!-- Splash screen icon configuration -->
        <meta-data
            android:name="androidx.core.splashscreen.SPLASH_SCREEN_STYLE"
            android:value="iconBackground" />

    </application>

</manifest>
